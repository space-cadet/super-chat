{
  "name": "super-chat",
  "version": "0.1.0",
  "description": "A standalone, reusable chat component library with LLM-native tool calling, multi-agent orchestration, and approval flow",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "demo": "pnpm build && vite --config demo/vite.config.ts",
    "demo:build": "pnpm build && vite build --config demo/vite.config.ts",
    "dev": "vite --config demo/vite.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:chat": "node scripts/test-chat-cli.mjs",
    "test:real": "node scripts/test-real.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "ai": "^6.0.174",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.78",
    "@ai-sdk/azure": "3.0.65",
    "@ai-sdk/deepseek": "2.0.35",
    "@ai-sdk/google": "3.0.75",
    "@ai-sdk/openai": "3.0.64",
    "@openrouter/ai-sdk-provider": "2.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "katex": "^0.16.0",
    "ollama-ai-provider": "1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "6.4.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "chat",
    "llm",
    "ai",
    "tool-calling",
    "multi-agent",
    "react",
    "typescript"
  ],
  "author": "Deepak Vaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/space-cadet/super-chat.git"
  }
}
